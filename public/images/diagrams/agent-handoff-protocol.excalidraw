      "x": 460,
      "y": 140,
      "width": 540,
      "height": 440,
      "text": "class HandoffPacket(BaseModel):\n    task_id:          str\n    original_goal:    str\n    priority:         Priority   # LOW|MEDIUM|HIGH|CRITICAL\n    confidence:       float      # 0.0..1.0\n    context_summary:  str\n    completed_steps:  list[Step]\n    remaining_steps:  list[Step]\n    working_memory:   dict\n    tool_cache:       dict[str, ToolResult]\n    created_at:       datetime\n    expires_at:       datetime | None\n\n# actual instance\nHandoffPacket(\n    task_id          = \"t42\",\n    original_goal    = \"write survey of sparse attention\",\n    priority         = Priority.HIGH,\n    confidence       = 0.78,\n    context_summary  = \"3 candidate papers found, reader agent next\",\n    completed_steps  = [\n        Step(\"arxiv.search\", args={\"q\":\"sparse attn\"},\n             out={\"hits\": 3}),\n    ],\n    remaining_steps  = [Step(\"read_pdf\"), Step(\"summarise\")],\n    working_memory   = {\"arxiv_hits\": [...]},\n    tool_cache       = {\n        \"arxiv.search:sparse attn\": ToolResult(...),\n    },\n    expires_at       = now() + timedelta(minutes=30),\n)",
      "originalText": "class HandoffPacket(BaseModel):\n    task_id:          str\n    original_goal:    str\n    priority:         Priority   # LOW|MEDIUM|HIGH|CRITICAL\n    confidence:       float      # 0.0..1.0\n    context_summary:  str\n    completed_steps:  list[Step]\n    remaining_steps:  list[Step]\n    working_memory:   dict\n    tool_cache:       dict[str, ToolResult]\n    created_at:       datetime\n    expires_at:       datetime | None\n\n# actual instance\nHandoffPacket(\n    task_id          = \"t42\",\n    original_goal    = \"write survey of sparse attention\",\n    priority         = Priority.HIGH,\n    confidence       = 0.78,\n    context_summary  = \"3 candidate papers found, reader agent next\",\n    completed_steps  = [\n        Step(\"arxiv.search\", args={\"q\":\"sparse attn\"},\n             out={\"hits\": 3}),\n    ],\n    remaining_steps  = [Step(\"read_pdf\"), Step(\"summarise\")],\n    working_memory   = {\"arxiv_hits\": [...]},\n    tool_cache       = {\n        \"arxiv.search:sparse attn\": ToolResult(...),\n    },\n    expires_at       = now() + timedelta(minutes=30),\n)",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "containerId": "packet_crect",
      "lineHeight": 1.25

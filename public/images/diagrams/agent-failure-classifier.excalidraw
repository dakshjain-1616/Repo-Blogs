      "x": 40,
      "y": 140,
      "width": 320,
      "height": 180,
      "text": "with TraceRecorder(run_id=\"r42\") as t:\n    result = my_agent.run(\n        \"book a flight to Tokyo\\n\"\n        \"on 2026-05-10\"\n    )\n\n# t.trace now holds:\n#  - tool calls (name, args, out)\n#  - latencies\n#  - agent messages\n#  - outputs",
      "originalText": "with TraceRecorder(run_id=\"r42\") as t:\n    result = my_agent.run(\n        \"book a flight to Tokyo\\n\"\n        \"on 2026-05-10\"\n    )\n\n# t.trace now holds:\n#  - tool calls (name, args, out)\n#  - latencies\n#  - agent messages\n#  - outputs",

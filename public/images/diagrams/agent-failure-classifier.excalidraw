      "y": 340,
      "width": 320,
      "height": 310,
      "text": "{\n  \"run_id\": \"r42\",\n  \"turns\": [\n    {\"role\":\"user\",\"text\":\"...\"},\n    {\"role\":\"agent\",\n     \"tool\":\"search_flights\",\n     \"args\":{\"dest\":\"NRT\"},\n     \"latency_ms\": 6200,\n     \"ok\": true},\n    {\"role\":\"agent\",\n     \"tool\":\"search_flights\",\n     \"args\":{\"dest\":\"NRT\"},\n     \"latency_ms\": 310,\n     \"ok\": true},\n    {\"role\":\"agent\",\n     \"tool\":\"book_flight_v9\",\n     \"args\":{},\n     \"latency_ms\": 0,\n     \"ok\": false,\n     \"err\":\"no such tool\"}\n  ]\n}",
      "originalText": "{\n  \"run_id\": \"r42\",\n  \"turns\": [\n    {\"role\":\"user\",\"text\":\"...\"},\n    {\"role\":\"agent\",\n     \"tool\":\"search_flights\",\n     \"args\":{\"dest\":\"NRT\"},\n     \"latency_ms\": 6200,\n     \"ok\": true},\n    {\"role\":\"agent\",\n     \"tool\":\"search_flights\",\n     \"args\":{\"dest\":\"NRT\"},\n     \"latency_ms\": 310,\n     \"ok\": true},\n    {\"role\":\"agent\",\n     \"tool\":\"book_flight_v9\",\n     \"args\":{},\n     \"latency_ms\": 0,\n     \"ok\": false,\n     \"err\":\"no such tool\"}\n  ]\n}",

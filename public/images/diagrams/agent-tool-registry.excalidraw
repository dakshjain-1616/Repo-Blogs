      "x": 420,
      "y": 230,
      "width": 560,
      "height": 180,
      "text": "POST /tools                # register (requires X-API-Key)\nGET  /tools/search?q=...   # semantic search\nGET  /tools/{id}           # tool detail + schema\nPOST /tools/{id}/invoke    # log + route call\nGET  /tools/{id}/analytics # call volume \u00b7 p50/p95/p99\nDELETE /tools/{id}         # remove (requires X-API-Key)\nGET  /health",
      "originalText": "POST /tools                # register (requires X-API-Key)\nGET  /tools/search?q=...   # semantic search\nGET  /tools/{id}           # tool detail + schema\nPOST /tools/{id}/invoke    # log + route call\nGET  /tools/{id}/analytics # call volume \u00b7 p50/p95/p99\nDELETE /tools/{id}         # remove (requires X-API-Key)\nGET  /health",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
